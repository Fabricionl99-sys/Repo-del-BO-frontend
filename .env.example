# Copy to .env for local development (file is gitignored).
# Vite modes: development (npm run dev), staging, production (build scripts).

VITE_APP_ENV=development
VITE_USE_MOCKS=true
# API origin without /v1 — the app appends /v1 to every request automatically.
VITE_API_BASE_URL=/api
VITE_CDN_BASE_URL=http://localhost
VITE_SENTRY_DSN=
VITE_WIDGET_PREVIEW_URL=https://widget.social2game.com/preview
VITE_DOCS_URL=https://docs.social2game.com
VITE_APP_VERSION=0.1.0
